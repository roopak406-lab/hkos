# ============================================================================
# HKOS environment variables. Copy to `.env.local` and fill in.
# Get these from your Supabase project → Settings → API.
# ============================================================================

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Deployed site origin. Local dev: http://localhost:5210
# Production custom domain example: https://order.aromatictadkakitchen.in
NEXT_PUBLIC_SITE_URL=http://localhost:5210

# Server-only SECRET — never commit, never expose to the client.
# Used by the public order-placement route to call the place_order RPC.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ----------------------------------------------------------------------------
# Business configuration for the public /order page.
# NOTE: Operational values (business name, tagline, UPI ID, WhatsApp number,
# cut-off, service area, delivery slots) are read from the `kitchens` row in the
# database — that is the source of truth and keeps the app multi-kitchen ready.
# The variables below are optional overrides / conveniences for the /order route.
# ----------------------------------------------------------------------------

# Which kitchen the bare /order URL resolves to (its `slug`).
NEXT_PUBLIC_DEFAULT_KITCHEN_SLUG=aromatic-tadka

# Customer-facing hosts whose ROOT ("/") should redirect straight to /order.
# Any host starting with "order." matches automatically (e.g.
# order.aromatictadkakitchen.in). Add extra hosts here, comma-separated.
NEXT_PUBLIC_CUSTOMER_HOSTS=order.aromatictadkakitchen.in

# Optional: a pre-generated UPI QR image URL. If unset, the app generates a
# UPI-intent QR (with the exact amount) on the confirmation screen from the
# kitchen's upi_id — so you normally do NOT need to set this.
NEXT_PUBLIC_UPI_QR_URL=

# Optional documentation mirrors of the DB business config (not required to run;
# the DB values above take precedence in the UI).
NEXT_PUBLIC_BUSINESS_NAME=Aromatic Tadka Kitchen
NEXT_PUBLIC_BUSINESS_TAGLINE=Authentic Flavours. Purely Homemade.
NEXT_PUBLIC_SERVICE_AREA=Fortuna Krrish Apartments only
NEXT_PUBLIC_ORDER_CUTOFF=18:00
NEXT_PUBLIC_UPI_ID=aromatictadka@okhdfc

# Server-only contact values (never exposed to the browser).
BUSINESS_CONTACT_NUMBER=
BUSINESS_WHATSAPP_NUMBER=
BUSINESS_EMAIL=

# ----------------------------------------------------------------------------
# Email order notifications (optional). Get a free API key at resend.com.
# When set, a new-order email is sent to the kitchen's "notification email"
# (configured in Admin -> Settings). Leave blank to disable email alerts.
# EMAIL_FROM must use a Resend-verified domain in production; for quick testing
# Resend allows "onboarding@resend.dev" to your own account email.
# ----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=HKOS Orders <onboarding@resend.dev>
